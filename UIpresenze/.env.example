# ==========================================
# CONFIGURAZIONE FRONTEND SVELTE
# ==========================================

# Porta per lo sviluppo locale (vite dev)
PORT=5173

# Backend API URL per sviluppo locale (opzionale, default: http://localhost:7999)
# PUBLIC_API_URL=http://localhost:7999
PUBLIC_API_BASE=/presenze
VITE_PROXY_TARGET=http://192.168.1.22:7999

# Nota: Le variabili con prefisso PUBLIC_ sono esposte al browser
# Non inserire mai segreti o credenziali qui!
