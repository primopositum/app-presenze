# ==========================================
# CONFIGURAZIONE DATABASE
# ==========================================
# Lascia vuoti per usare SQLite (sviluppo)
# Compila per usare PostgreSQL (produzione)

DB_NAME=gestionaledb
DB_USER=postgres
DB_PASSWORD=cambia_con_password_sicura
DB_HOST=localhost
DB_PORT=5432

# ==========================================
# DJANGO SETTINGS
# ==========================================

# SECRET_KEY: genera una chiave unica per la produzione
# Usa: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-cambia-questa-chiave-in-produzione

# DEBUG: True per sviluppo, False per produzione
DEBUG=True

# ALLOWED_HOSTS: host autorizzati ad accedere all'applicazione
# Separa multipli valori con virgola
ALLOWED_HOSTS=localhost,127.0.0.1

# ==========================================
# CORS SETTINGS
# ==========================================

# Origini consentite per le richieste CORS (frontend)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3623

# ==========================================
# PORT SETTINGS
# ==========================================

# Porta su cui gira il backend
PORT=7999

# ==========================================
# NOTE IMPORTANTI
# ==========================================
# 1. Non committare mai questo file con dati reali nel repository
# 2. Per la produzione, usa valori sicuri e unici per SECRET_KEY
# 3. Per PostgreSQL, assicurati che il database esista prima di avviare
# 4. Se usi Docker, le variabili saranno disponibili nel container
